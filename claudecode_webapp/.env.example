# ========================
# Claude AI Chat - 環境変数テンプレート
# ========================
#
# 使用方法:
# 1. このファイルを .env にコピー: cp .env.example .env
# 2. 下記の認証情報を入力
# 3. npm start を実行
#
# ========================

# ========================
# API 認証情報（必須）
# 以下のいずれか一つを設定してください
# ========================

# 【推奨】Anthropic Claude API キー
# https://console.anthropic.com から取得
CLAUDE_API_KEY=sk-your-api-key-here

# 【代替】AWS Bedrock 認証情報
# AWS マネジメントコンソールから取得
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_SESSION_TOKEN=your-session-token-optional
AWS_REGION=ap-northeast-1

# ========================
# サーバー設定（オプション）
# ========================

# ポート番号（デフォルト: 3002）
PORT=3002

# API タイプ（bedrock または claude）
# 自動選択: CLAUDE_API_KEY が設定されていれば claude、それ以外は bedrock
API_TYPE=bedrock

# ========================
# AWS VPC エンドポイント（オプション）
# 企業ネットワークで使用する場合のみ設定
# ========================

# AWS_ENDPOINT_URL=https://bedrock-runtime.ap-northeast-1.vpce.amazonaws.com

# ========================
# プロキシ設定（オプション）
# 企業プロキシを使用する場合
# ========================

# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=https://proxy.example.com:8080
# NO_PROXY=localhost,127.0.0.1

# ========================
# その他の設定
# ========================

# ノード環境
NODE_ENV=development

# ログレベル（info、warn、error）
LOG_LEVEL=info
